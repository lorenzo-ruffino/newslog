# --- Required ---
BASE_URL=https://newslog.yourdomain.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM=NewsLog <noreply@example.com>
# Generate with: openssl rand -hex 48
SECRET_KEY=generate-a-random-long-string

# --- Optional ---
PORT=3000
MAX_UPLOAD_SIZE=52428800
DEFAULT_LOCALE=en
CORS_ORIGINS=

# --- S3 Backup (optional) ---
S3_BACKUP_ENABLED=false
S3_ENDPOINT=https://s3.amazonaws.com
S3_REGION=eu-west-1
S3_BUCKET=newslog-backups
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BACKUP_SCHEDULE=0 3 * * *
S3_BACKUP_RETENTION=30
S3_BACKUP_ENCRYPTION=AES256
